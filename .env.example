# ==============================================================================
# CampusRide Environment Configuration Template
# Copy this file to .env at the root or within subfolders for local development.
# ==============================================================================

# --- DATABASE (PostgreSQL) ---
POSTGRES_USER=campusride
POSTGRES_PASSWORD=campusride_password
POSTGRES_DB=campusride_db
DATABASE_URL=postgresql://campusride:campusride_password@localhost:5432/campusride_db?schema=public

# --- BACKEND API SETTINGS ---
PORT=4001
NODE_ENV=development
BCRYPT_SALT_ROUNDS=12
CORS_ORIGIN=http://localhost:3000

# --- JWT AUTHORIZATION SECRETS ---
# Note: In production, generate strong 32+ character secrets
JWT_ACCESS_SECRET=dev_access_secret_replace_in_production_super_long
JWT_REFRESH_SECRET=dev_refresh_secret_replace_in_production_super_long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- FRONTEND (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:4001/api/v1
NEXT_PUBLIC_SOCKET_URL=http://localhost:4001
